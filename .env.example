# ============================================================
# Weave Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# --- Required ---
GROQ_API_KEY=your_groq_api_key_here

# --- Vector Store ---
# Use /app/chroma_data inside Docker, or an absolute path locally
CHROMA_PATH=/app/chroma_data

# --- Database URIs ---
# Use service names (postgres, mongodb, neo4j) inside Docker
# Use localhost if running outside Docker
POSTGRES_URI=postgresql://admin:<your-db-password>@postgres:5432/weave_db
MONGO_URI=mongodb://admin:<your-db-password>@mongodb:27017/
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-db-password>
